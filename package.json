{
  "name": "@shahmarasy/prodo",
  "version": "0.1.4",
  "description": "CLI-first, prompt-powered product artifact kit",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": {
    "prodo": "bin/prodo.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/",
    "presets/",
    "src/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.cjs",
    "verify:release": "npm run build && node scripts/verify-release-build.cjs"
  },
  "keywords": [
    "product-management",
    "prd",
    "ai-agents",
    "codex",
    "claude",
    "gemini",
    "document-generation",
    "cli"
  ],
  "author": "Shahmarasy",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "nunjucks": "^3.2.4"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.20.0",
    "@google/generative-ai": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true },
    "@google/generative-ai": { "optional": true }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6",
    "typescript": "^5.9.3"
  }
}
